{
  "comment": "ROM Organizer Configuration - Customize platform detection and file extensions",
  "platforms": {
    "nes": {
      "name": "Nintendo Entertainment System",
      "extensions": [".nes", ".unf", ".unif"],
      "aliases": ["famicom", "fc"]
    },
    "snes": {
      "name": "Super Nintendo Entertainment System",
      "extensions": [".smc", ".sfc", ".fig", ".swc", ".mgd"],
      "aliases": ["superfamicom", "sfc"]
    },
    "n64": {
      "name": "Nintendo 64",
      "extensions": [".z64", ".n64", ".v64"],
