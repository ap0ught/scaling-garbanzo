      "aliases": ["playstation", "ps1", "psone"]
    },
    "ps2": {
      "name": "Sony PlayStation 2",
      "extensions": [".iso", ".bin", ".img", ".mdf", ".z", ".z2", ".bz2", ".dump", ".cso", ".ima", ".gz", ".chd"],
      "aliases": ["playstation2"]
    },
    "psp": {
